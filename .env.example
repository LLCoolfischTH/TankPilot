# TankPilot – Umgebungsvariablen
# Kopiere diese Datei nach backend/.env

# ── Deutschland: Tankerkönig (Bundeskartellamt MTS-K) ──────────────────────────
# Kein eigener Key nötig für MVP – Demo-Key funktioniert sofort
# Eigener Key: https://creativecommons.tankerkoenig.de
TANKERKOENING_API_KEY=00000000-0000-0000-0000-000000000002

# ── Österreich: E-Control Spritpreisrechner ────────────────────────────────────
# Kein Key nötig! Öffentliche API, wird automatisch für AT-Koordinaten genutzt.

# ── Polen, Tschechien, NL, BE, FR, CH, LU, DK: HERE Fuel Prices API ───────────
# Freemium: 250.000 Anfragen/Monat kostenlos
# Key registrieren: https://developer.here.com → Sign up → Projekt → API Key
# Ohne Key: diese Länder liefern keine Ergebnisse (klare Fehlermeldung)
HERE_API_KEY=dein_here_api_key_hier

# ── Routing: OpenRouteService (echte Straßendistanz) ──────────────────────────
# Ohne Key: Haversine-Schätzung (Luftlinie × 1.3) als Fallback
# Kostenlos: https://openrouteservice.org/dev/#/signup (2.000 Req/Tag)
ORS_API_KEY=dein_ors_api_key_hier

# ── Währungsumrechnung (PLN, CZK, CHF ...) ────────────────────────────────────
# open.er-api.com wird automatisch genutzt (kostenlos, kein Key)
# Fallback: Hardcodierte Näherungskurse in currencyService.js

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
