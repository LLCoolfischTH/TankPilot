# ── TankPilot Backend – Umgebungsvariablen ──────────────────────────────────
# Kopiere diese Datei: cp .env.example .env
# Trage dann deine Keys ein.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Tankerkönig API ─────────────────────────────────────────────────────────
# Kostenlosen Key registrieren unter:
# https://creativecommons.tankerkoenig.de
#
# Ohne eigenen Key läuft der Demo-Key (begrenzte Anfragen/Tag).
# Eigener Key hat 10.000 Anfragen/Tag kostenlos.
#
TANKERKOENING_API_KEY=dein_tankerkoenig_key

# ── OpenRouteService API ─────────────────────────────────────────────────────
# Kostenlos registrieren (2.000 Routing-Anfragen/Tag gratis):
# https://openrouteservice.org/dev/#/signup
#
# OHNE Key: Haversine-Fallback (Luftlinie × 1,3) – Schätzung ±20%
# MIT Key:  Echte Straßendistanz via Routing-Engine
#
ORS_API_KEY=dein_ors_api_key_hier
